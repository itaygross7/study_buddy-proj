def process_payment(amount: float, currency: str) -> bool:
    """
    Charge the payment processor for the given amount and currency.
    :param amount: Charge amount in the specified currency.
    :param currency: ISO 4217 currency code (e.g., "USD").
    :return: True if the processor confirmed the charge.
    :raises PaymentDeclinedError: If the processor rejects the charge.
    """
    try:
        result = self._processor.charge(amount, currency)
    except:                   # <-- PROBLEM: catches everything, hides root cause
        return False          # <-- PROBLEM: silent failure, caller has no error context
    return result.success
```

REPLACE WITH:
```python
def process_payment(amount: float, currency: str) -> bool:
    """
    Charge the payment processor for the given amount and currency.
    :param amount: Charge amount in the specified currency.
    :param currency: ISO 4217 currency code (e.g., "USD").
    :return: True if the processor confirmed the charge.
    :raises PaymentDeclinedError: If the processor rejects the charge.
    """
    try:
        result = self._processor.charge(amount, currency)
    except ProcessorError as e:                                                          # CHANGED
        logger.exception("Processor charge failed amount=%s currency=%s", amount, currency)  # ADDED
        raise PaymentDeclinedError("Payment declined by processor") from e               # CHANGED
    return result.success
```
